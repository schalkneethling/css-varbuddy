{
  "name": "css-varbuddy",
  "displayName": "CSS VarBuddy",
  "description": "Index, find, and use your CSS custom properties in a snap.",
  "icon": "images/css-varbuddy.png",
  "version": "0.5.4",
  "engines": {
    "vscode": "^1.118.0"
  },
  "publisher": "schalkneethling",
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/schalkneethling/css-varbuddy/"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "css-custom-props-explorer",
          "title": "CSS Custom Properties",
          "icon": "$(symbol-color)"
        }
      ]
    },
    "views": {
      "css-custom-props-explorer": [
        {
          "type": "webview",
          "id": "cssCustomPropertiesView",
          "name": "Custom Properties",
          "when": "true"
        }
      ]
    },
    "commands": []
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "vsce package",
    "publish": "pnpm run package && vsce publish",
    "publish:patch": "pnpm version patch && pnpm run package && vsce publish",
    "publish:minor": "pnpm version minor && pnpm run package && vsce publish",
    "publish:major": "pnpm version major && pnpm run package && vsce publish"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.9",
    "@types/node": "25.x",
    "@types/vscode": "^1.120.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.4.2",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.1.2"
}
